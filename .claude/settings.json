{
  "permissions": {
    "allow": [
      "# ========== FILE & FOLDER OPERATIONS ==========",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(find:*)",
      "Bash(cd:*)",
      "# ========== READ & WRITE ALL PROJECT FILES ==========",
      "Read(path_to_jarvis/**)",
      "Write(path_to_jarvis/**)",
      "# ========== DOCUMENT & FORMAT CONVERSION ==========",
      "Bash(pandoc:*)",
      "Bash(textutil:*)",
      "# ========== ENVIRONMENT & SOURCING ==========",
      "Bash(source:*)",
      "Bash(export:*)",
      "# ========== GIT OPERATIONS ==========",
      "Bash(git:*)",
      "# ========== PYTHON EXECUTION (ALL) ==========",
      "Bash(python3:*)",
      "Bash(conda:*)",
      "# ========== PACKAGE MANAGEMENT (EXISTING PACKAGES ONLY) ==========",
      "Bash(pip3 install -r:*)",
      "Bash(pip3 list:*)",
      "Bash(pip3 show:*)",
      "Bash(pip3 freeze:*)",
      "Bash(npm:*)",
      "# ========== TEMP & DATA FILES ==========",
      "Read(/tmp/**)",
      "Write(/tmp/**)",
      "Bash(/tmp/**)",
      "# ========== SETUP ==========",
      "Bash(gcloud auth:*)"
